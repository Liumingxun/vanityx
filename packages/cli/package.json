{
  "name": "@vanityx/cli",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.28.0",
  "description": "A command-line tool for searching Ethereum CREATE2 vanity addresses.",
  "author": "lime <liumingxun@yeah.net>",
  "license": "ISC",
  "keywords": [
    "vanity",
    "address",
    "ethereum",
    "create2",
    "createx"
  ],
  "imports": {
    "#main": "./src/index.ts",
    "#type": "./src/cli.type.ts"
  },
  "bin": {
    "vanityx": "./bin/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "bun run ./bin/index.ts",
    "build": "bun build --compile --bytecode --minify bin/index.ts src/worker.ts --outfile=dist/vanityx"
  },
  "dependencies": {
    "@cliffy/command": "catalog:",
    "vanityx": "workspace:*"
  }
}
