{
  "name": "vanityx",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.28.0",
  "description": "Generate vanity Ethereum addresses using CREATE2.",
  "author": "lime <liumingxun@yeah.net>",
  "license": "ISC",
  "keywords": [
    "vanity",
    "address",
    "ethereum",
    "create2",
    "createx"
  ],
  "imports": {
    "#schema": "./src/schema.ts"
  },
  "main": "src/index.ts",
  "bin": "dist/index.cjs",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test": "find ./tests -name \"*.case.ts\" | xargs -P4 -I{} bash -c 'time pnpx tsx {}'",
    "build:bin": "pnpx tsx scripts/build.bin.ts"
  },
  "dependencies": {
    "micromatch": "catalog:",
    "viem": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@types/micromatch": "catalog:",
    "@types/node": "catalog:",
    "commander": "catalog:",
    "createx_guard": "workspace:*",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-format": "catalog:",
    "typescript": "catalog:"
  },
  "workspaces": [
    "packages/*"
  ]
}
