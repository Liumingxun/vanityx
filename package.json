{
  "name": "vanityx",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.28.0",
  "description": "Generate vanity Ethereum addresses using CREATE2.",
  "author": "",
  "license": "ISC",
  "keywords": [
    "vanity",
    "address",
    "ethereum",
    "create2",
    "createx"
  ],
  "main": "src/index.ts",
  "bin": "dist/index.cjs",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test": "pnpx tsx ./bin/index.ts",
    "build": "node ./scripts/build.bin.ts",
    "prepublish": "pnpm run build"
  },
  "dependencies": {
    "viem": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@types/node": "catalog:",
    "commander": "catalog:",
    "createx_guard": "workspace:*",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-format": "catalog:"
  },
  "workspaces": [
    "packages/*"
  ]
}
