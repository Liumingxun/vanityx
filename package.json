{
  "name": "vanityx",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.28.0",
  "description": "A TypeScript library for searching Ethereum CREATE2 vanity addresses.",
  "author": "lime <liumingxun@yeah.net>",
  "license": "ISC",
  "keywords": [
    "vanity",
    "address",
    "ethereum",
    "create2",
    "createx"
  ],
  "imports": {
    "#schema": "./src/schema.ts",
    "#search": "./src/search.ts",
    "#types": "./types/index.ts"
  },
  "exports": {
    ".": "./src/search.ts",
    "./schema": "./src/schema.ts"
  },
  "files": [
    "src",
    "types"
  ],
  "scripts": {
    "bench": "bun run --sequential bench/*.bench.ts"
  },
  "dependencies": {
    "@vanityx/createx_guard": "workspace:*",
    "bun": "catalog:",
    "viem": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@types/bun": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-format": "catalog:",
    "mitata": "catalog:",
    "typescript": "catalog:"
  },
  "workspaces": [
    "packages/*"
  ]
}
